# ─────────────────────────────────────────────
# TRUEQUE — Variables de entorno (plantilla)
# Copia este archivo como .env y llena los valores
# NUNCA subas .env a git
# ─────────────────────────────────────────────

# MercadoPago — obtén tus credenciales en:
# https://www.mercadopago.com.mx/developers/panel/app
#
# Producción (cobros reales):  empieza con APP_USR-
# Sandbox (pruebas, sin cobrar): empieza con TEST-
#
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL pública de tu servidor en Render (sin / al final)
# La obtienes después de crear el servicio en render.com
BASE_URL=https://trueque-pagos.onrender.com
